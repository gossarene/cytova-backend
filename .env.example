# =============================================================================
# Cytova Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# Django core
SECRET_KEY=change-me-use-a-long-random-string-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Database (PostgreSQL)
DB_NAME=cytova
DB_USER=cytova_user
DB_PASSWORD=cytova_password
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
# Development: HS256 uses SECRET_KEY by default — no extra config needed.
# Production: set RS256 keys below (use \n for newlines in single-line env vars).
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# File storage
# Set USE_S3=True in production and configure the fields below.
USE_S3=False
# STORAGE_BUCKET_NAME=cytova-files
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_REGION=eu-west-1
# STORAGE_ENDPOINT_URL=   # MinIO or S3-compatible endpoint

# Email
# Development: console backend prints emails to stdout.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@cytova.io
SERVER_EMAIL=errors@cytova.io
# Production SMTP:
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

# Platform
CYTOVA_DOMAIN=cytova.io
SHOW_PUBLIC_IF_NO_TENANT_FOUND=True

# CORS (production — comma-separated list)
# CORS_ALLOWED_ORIGINS=https://laba.cytova.io,https://admin.cytova.io
